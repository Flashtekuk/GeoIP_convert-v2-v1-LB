{
    "version": 1,
    "disable_existing_loggers": false,
    "formatters": {
        "detailed": {
            "format": "%(asctime)s | %(levelname)-8s | %(name)-12s | %(message)s",
            "datefmt": "%Y-%m-%d %H:%M:%S"
        }
    },
    "handlers": {
        "stdout": {
            "class": "logging.StreamHandler",
            "formatter": "detailed",
            "stream": "ext://sys.stdout"
        },
        "file": {
            "class": "logging.handlers.RotatingFileHandler",
            "level": "INFO",
            "formatter": "detailed",
            "filename": "data/appliance.log",
            "maxBytes": 5242880,
            "backupCount": 5,
            "encoding": "utf8"
        }
    },
    "loggers": {
        "root": {
            "level": "INFO",
            "handlers": [
                "stdout",
                "file"
            ]
        }
    }
}